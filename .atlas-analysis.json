    "pyxel.pset(x, y, col) / pget(x, y)",
    "pyxel.line(x1, y1, x2, y2, col)",
    "pyxel.rect(x, y, w, h, col) / rectb(...)",
    "pyxel.circ(x, y, r, col) / circb(...)",
    "pyxel.blt(x, y, img, u, v, w, h, ...)",
    "pyxel.bltm(x, y, tm, u, v, w, h, ...)",
    "pyxel.text(x, y, s, col)",
    "pyxel.play(ch, snd, ...) / playm(msc, ...)",
    "pyxel.stop(ch)",
    "pyxel.images[0..2] — Image banks",
    "pyxel.tilemaps[0..7] — Tilemap banks",
    "pyxel.sounds[0..63] — Sound slots",
    "pyxel.musics[0..7] — Music tracks",
    "pyxel.colors — 16-color palette",
    "Image.set() / Image.load()",
    "Tilemap.set() / Tilemap.collide()",
    "Sound.set() / Sound.mml() / Sound.pcm()",
    "Music.set()",
    "pyxel.noise(x, y, z) / nseed(seed)",
    "pyxel.rndi(a, b) / rndf(a, b)",
